<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Chess Arena - Live multiplayer chess game room">
  <title>Chess Arena - Game</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div id="app">
    <header class="top-bar">
      <a href="/" class="logo-link">
        <span class="logo-sm">♞</span>
        <span class="logo-text">Chess Arena</span>
      </a>
      <div class="room-info">
        <span class="room-label">Room:</span>
        <span class="room-code" id="roomCode"><%= roomId %></span>
        <button class="btn-icon" id="copyRoomBtn" title="Copy Room ID">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        </button>
      </div>
      <div class="connection-status" id="connectionStatus">
        <span class="status-dot connected"></span>
        <span>Connected</span>
      </div>
    </header>

    <main class="game-layout">
      <div class="board-column">
        <div class="player-bar top-player" id="topPlayer">
          <div class="player-info">
            <div class="player-avatar" id="topPlayerAvatar">B</div>
            <div class="player-details">
              <span class="player-name" id="topPlayerName">Black</span>
              <div class="captured-pieces" id="topCaptured"></div>
            </div>
          </div>
          <div class="timer" id="topTimer">10:00</div>
        </div>

        <div class="board-wrapper">
          <div class="board-container" id="boardContainer">
            <div class="rank-labels left" id="rankLabelsLeft"></div>
            <div class="chess-board" id="chessBoard"></div>
            <div class="rank-labels right" id="rankLabelsRight"></div>
            <div class="file-labels" id="fileLabels"></div>
          </div>
        </div>

        <div class="player-bar bottom-player" id="bottomPlayer">
          <div class="player-info">
            <div class="player-avatar accent" id="bottomPlayerAvatar">W</div>
            <div class="player-details">
              <span class="player-name" id="bottomPlayerName">White</span>
              <div class="captured-pieces" id="bottomCaptured"></div>
            </div>
          </div>
          <div class="timer active" id="bottomTimer">10:00</div>
        </div>
      </div>

      <div class="side-panel">
        <div class="panel-card status-card">
          <div class="game-status" id="gameStatus">
            <span class="status-icon">⏳</span>
            <span class="status-text">Waiting for opponent...</span>
          </div>
          <div class="role-badge" id="roleBadge">
            <span id="roleText">—</span>
          </div>
        </div>

        <div class="panel-card moves-card">
          <div class="panel-header">
            <h3>Moves</h3>
            <span class="move-count" id="moveCount">0</span>
          </div>
          <div class="moves-list" id="movesList">
            <div class="moves-empty">No moves yet</div>
          </div>
        </div>

        <div class="panel-card actions-card" id="actionsCard">
          <div class="action-buttons" id="actionButtons">
            <button class="btn-action" id="flipBtn" title="Flip Board">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><polyline points="23 20 23 14 17 14"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg>
              <span>Flip</span>
            </button>
            <button class="btn-action" id="drawBtn" title="Offer Draw">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12" opacity="0.5"/><circle cx="12" cy="12" r="10"/></svg>
              <span>Draw</span>
            </button>
            <button class="btn-action" id="undoBtn" title="Request Undo">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
              <span>Undo</span>
            </button>
            <button class="btn-action btn-danger" id="resignBtn" title="Resign">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
              <span>Resign</span>
            </button>
          </div>
        </div>
      </div>
    </main>
  </div>

  <div class="modal-overlay" id="promotionModal">
    <div class="modal promotion-modal">
      <h3>Choose Promotion</h3>
      <div class="promotion-options" id="promotionOptions"></div>
    </div>
  </div>

  <div class="modal-overlay" id="gameOverModal">
    <div class="modal game-over-modal">
      <div class="game-over-icon" id="gameOverIcon">🏆</div>
      <h2 id="gameOverTitle">Game Over</h2>
      <p id="gameOverReason"></p>
      <div class="game-over-actions">
        <button class="btn-modal btn-primary-modal" id="playAgainBtn">Play Again</button>
        <a href="/" class="btn-modal btn-secondary-modal">New Room</a>
      </div>
    </div>
  </div>

  <div class="modal-overlay" id="drawOfferModal">
    <div class="modal offer-modal">
      <h3>Draw Offered</h3>
      <p>Your opponent is offering a draw.</p>
      <div class="offer-actions">
        <button class="btn-modal btn-primary-modal" id="acceptDrawBtn">Accept</button>
        <button class="btn-modal btn-secondary-modal" id="rejectDrawBtn">Decline</button>
      </div>
    </div>
  </div>

  <div class="modal-overlay" id="undoOfferModal">
    <div class="modal offer-modal">
      <h3>Undo Requested</h3>
      <p>Your opponent wants to undo the last move.</p>
      <div class="offer-actions">
        <button class="btn-modal btn-primary-modal" id="acceptUndoBtn">Accept</button>
        <button class="btn-modal btn-secondary-modal" id="rejectUndoBtn">Decline</button>
      </div>
    </div>
  </div>

  <div class="toast-container" id="toastContainer"></div>

  <script>
    const ROOM_ID = '<%= roomId %>';
  </script>
  <script src="/socket.io/socket.io.js"></script>
  <script src="/js/chess-game.js"></script>
  <script src="/js/socket-client.js"></script>
</body>
</html>
